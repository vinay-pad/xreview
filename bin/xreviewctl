#!/usr/bin/env python3
import argparse
import json
import os
import pathlib
import subprocess
import sys
import time
import urllib.error
import urllib.request


HOST = os.environ.get("XREVIEWD_HOST", "127.0.0.1")
PORT = int(os.environ.get("XREVIEWD_PORT", "8765"))


def repo_root() -> pathlib.Path:
    return pathlib.Path(__file__).resolve().parents[1]


def daemon_url(path: str) -> str:
    return f"http://{HOST}:{PORT}{path}"


def daemon_health() -> bool:
    try:
        with urllib.request.urlopen(daemon_url("/health"), timeout=1) as response:
            return response.status == 200
    except Exception:
        return False


def start_daemon() -> None:
    if daemon_health():
        return
    root = repo_root()
    script = root / "bin" / "xreviewd"
    logs = root / "logs"
    logs.mkdir(parents=True, exist_ok=True)
    log_file = logs / "xreviewd.log"
    with log_file.open("a") as stream:
        subprocess.Popen(
            [str(script), "--host", HOST, "--port", str(PORT)],
            stdout=stream,
            stderr=stream,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    deadline = time.time() + 10
    while time.time() < deadline:
        if daemon_health():
            return
        time.sleep(0.25)
    raise RuntimeError("xreviewd failed to start")


def review(args) -> int:
    start_daemon()
    prompt = sys.stdin.read()
    request = urllib.request.Request(
        daemon_url("/v1/review"),
        data=json.dumps({"reviewer": args.reviewer, "cwd": args.cwd, "prompt": prompt}).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=args.timeout) as response:
        payload = json.loads(response.read())
    print(payload["response"])
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    subparsers = parser.add_subparsers(dest="command", required=True)

    review_parser = subparsers.add_parser("review")
    review_parser.add_argument("--reviewer", required=True, choices=["claude", "codex"])
    review_parser.add_argument("--cwd", default=os.getcwd())
    review_parser.add_argument("--timeout", type=int, default=240)
    review_parser.set_defaults(func=review)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
